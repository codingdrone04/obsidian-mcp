# ── OAuth Security ──────────────────────────────────────────────────
# Password shown on the consent screen — CHANGE THIS
CONSENT_PASSWORD=changeme123

# Secret required to call POST /oauth/register and POST /admin/backup.
# Clients must send: Authorization: Bearer <value>
# Leave empty to disable the guard (not recommended in production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REGISTRATION_SECRET=

# Public domain of the server (used in OAuth metadata & redirects)
OAUTH_DOMAIN=https://your-domain.example.com

# Access token lifetime in seconds (default: 1 hour)
TOKEN_EXPIRY_SECONDS=3600

# Secret used to sign JWTs — CHANGE THIS to a long random string
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# ── MCP / Server ────────────────────────────────────────────────────
# Absolute path to your Obsidian vault
VAULT_PATH=/vault

# Server bind address & port (inside Docker)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# uvicorn log level: debug | info | warning | error
LOG_LEVEL=info

# ── Auth persistence ─────────────────────────────────────────────────
# SQLite database path (inside Docker, persisted via mcp-data volume)
DB_PATH=/data/auth.db

# ── Rate limiting ────────────────────────────────────────────────────
# Max failed consent attempts per IP before 429
RATE_LIMIT_MAX=5
# Time window in seconds (default: 5 minutes)
RATE_LIMIT_WINDOW=300
